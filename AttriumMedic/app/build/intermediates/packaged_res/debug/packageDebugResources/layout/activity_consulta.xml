<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAF9"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/menuInferior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Timeline"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1A2B22"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Suas Consultas"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1A2B22"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Acompanhe seu histórico e retornos"
                android:textSize="14sp"
                android:textColor="#6B8E7B"
                android:layout_marginBottom="24dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@android:color/white">

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dr. Ricardo Almeida" android:textSize="18sp" android:textStyle="bold" android:textColor="#333"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cardiologia" android:textColor="#888"/>
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:background="#F59E0B" android:paddingHorizontal="12dp" android:paddingVertical="6dp" android:text="Aguardando Retorno" android:textColor="@android:color/white" android:textSize="12sp" android:textStyle="bold"/>
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="12dp" android:background="#E5E7EB" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="19 de março de 2026" android:textColor="#666" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Consulta de retorno agendada." android:textStyle="italic" android:textColor="#888"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@android:color/white">

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dr. Fernando Costa" android:textSize="18sp" android:textStyle="bold" android:textColor="#333"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ortopedia" android:textColor="#888"/>
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:background="#F59E0B" android:paddingHorizontal="12dp" android:paddingVertical="6dp" android:text="Aguardando Retorno" android:textColor="@android:color/white" android:textSize="12sp" android:textStyle="bold"/>
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="12dp" android:background="#E5E7EB" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="09 de março de 2026" android:textColor="#666" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Retorno para avaliação do joelho em 30 dias." android:textStyle="italic" android:textColor="#888"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@android:color/white">

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dra. Camila Santos" android:textSize="18sp" android:textStyle="bold" android:textColor="#333"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pediatria" android:textColor="#888"/>
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:background="#10B981" android:paddingHorizontal="12dp" android:paddingVertical="6dp" android:text="Realizada" android:textColor="@android:color/white" android:textSize="12sp" android:textStyle="bold"/>
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="12dp" android:background="#E5E7EB" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="27 de fevereiro de 2026" android:textColor="#666" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Consulta de rotina. Vacinas em dia." android:textStyle="italic" android:textColor="#888"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@android:color/white">

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dra. Juliana Oliveira" android:textSize="18sp" android:textStyle="bold" android:textColor="#333"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dermatologia" android:textColor="#888"/>
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:background="#EF4444" android:paddingHorizontal="12dp" android:paddingVertical="6dp" android:text="Prazo Expirado" android:textColor="@android:color/white" android:textSize="12sp" android:textStyle="bold"/>
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="12dp" android:background="#E5E7EB" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="09 de janeiro de 2026" android:textColor="#666" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Retorno não realizado dentro do prazo de 45 dias." android:textStyle="italic" android:textColor="#888"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@android:color/white">

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dr. Carlos Mendes" android:textSize="18sp" android:textStyle="bold" android:textColor="#333"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Oftalmologia" android:textColor="#888"/>
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:background="#F59E0B" android:paddingHorizontal="12dp" android:paddingVertical="6dp" android:text="Aguardando Retorno" android:textColor="@android:color/white" android:textSize="12sp" android:textStyle="bold"/>
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="12dp" android:background="#E5E7EB" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15 de abril de 2026" android:textColor="#666" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Exame de vista agendado." android:textStyle="italic" android:textColor="#888"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/menuInferior"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_alignParentBottom="true"
        android:background="@android:color/white"
        android:elevation="12dp"
        android:gravity="top"
        android:paddingTop="12dp"
        android:orientation="horizontal"
        android:weightSum="4">

        <FrameLayout
            android:id="@+id/btnNavInicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:foreground="?android:attr/selectableItemBackground">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:src="@drawable/home"
                app:tint="#888888" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnNavMedicos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:foreground="?android:attr/selectableItemBackground">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:src="@drawable/medicos"
                app:tint="#888888" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnNavConsultas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:foreground="?android:attr/selectableItemBackground">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:src="@drawable/consultas"
                app:tint="#4CAF50" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnNavPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:foreground="?android:attr/selectableItemBackground">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:src="@drawable/perfil"
                app:tint="#888888" />
        </FrameLayout>

    </LinearLayout>

</RelativeLayout>